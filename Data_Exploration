-- checks for the count of nulls in each column --
SELECT COUNT(*) - COUNT(ride_id) ride_id,
 COUNT(*) - COUNT(rideable_type) rideable_type,
 COUNT(*) - COUNT(started_at) started_at,
 COUNT(*) - COUNT(ended_at) ended_at,
 COUNT(*) - COUNT(start_station_name) start_station_name,
 COUNT(*) - COUNT(start_station_id) start_station_id,
 COUNT(*) - COUNT(end_station_name) end_station_name,
 COUNT(*) - COUNT(end_station_id) end_station_id,
 COUNT(*) - COUNT(start_lat) start_lat,
 COUNT(*) - COUNT(start_lng) start_lng,
 COUNT(*) - COUNT(end_lat) end_lat,
 COUNT(*) - COUNT(end_lng) end_lng,
 COUNT(*) - COUNT(member_casual) member_casual
FROM `angular-sorter-489815-g2.Cyclistic_bikeshare_data.12_month_data`;

-- reveals the amount of duplicate rows in the table --

SELECT COUNT(ride_id) - COUNT(DISTINCT ride_id) AS duplicate_rows
FROM `angular-sorter-489815-g2.Cyclistic_bikeshare_data.12_month_data`;

-- reveals the rows by the length of their ride_id, which all end up being 16 --

SELECT LENGTH(ride_id) AS length_ride_id, COUNT(ride_id) AS number_of_rows
FROM `angular-sorter-489815-g2.Cyclistic_bikeshare_data.12_month_data`
GROUP BY length_ride_id; 

-- reveals the number of trips by rideable type, which is either electric or classic --

SELECT DISTINCT rideable_type, COUNT(rideable_type) AS number_of_trips
FROM `angular-sorter-489815-g2.Cyclistic_bikeshare_data.12_month_data`
GROUP BY rideable_type;

-- reveals the number of trips by member type, which is either casual or annual member --

SELECT member_casual, COUNT(member_casual) AS number_of_trips
FROM `angular-sorter-489815-g2.Cyclistic_bikeshare_data.12_month_data`
GROUP BY member_casual;
